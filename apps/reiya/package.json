{
  "name": "@shikanime-studio/reiya",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "astro build",
    "check": "astro check",
    "check:fix": "astro check --fix",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply reiya",
    "db:seed": "SEED_FILE=$(tsx src/seed.ts) && wrangler d1 execute reiya --file=$SEED_FILE --yes && rm $SEED_FILE",
    "db:studio": "drizzle-kit studio",
    "deploy": "wrangler deploy",
    "dev": "astro dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "astro preview",
    "start": "astro dev",
    "types": "wrangler types src/worker-configuration.d.ts",
    "upload": "wrangler versions upload"
  },
  "dependencies": {
    "@astrojs/check": "catalog:types",
    "@astrojs/cloudflare": "catalog:build",
    "@astrojs/partytown": "catalog:runtime",
    "@astrojs/react": "catalog:runtime",
    "@astrojs/sitemap": "catalog:runtime",
    "@better-auth/passkey": "catalog:runtime",
    "@fontsource-variable/bricolage-grotesque": "catalog:runtime",
    "@tailwindcss/typography": "catalog:runtime",
    "@tailwindcss/vite": "catalog:build",
    "@tanstack/react-query": "catalog:runtime",
    "@types/node": "catalog:types",
    "@unpic/react": "catalog:runtime",
    "astro": "catalog:build",
    "better-auth": "catalog:runtime",
    "daisyui": "catalog:runtime",
    "drizzle-orm": "catalog:runtime",
    "drizzle-seed": "catalog:runtime",
    "lucide-react": "catalog:runtime",
    "react": "catalog:runtime",
    "react-dom": "catalog:runtime",
    "simple-icons": "catalog:runtime",
    "tailwindcss": "catalog:runtime",
    "usehooks-ts": "catalog:runtime",
    "zod": "catalog:runtime"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:lint",
    "@e18e/eslint-plugin": "catalog:lint",
    "@eslint-react/eslint-plugin": "catalog:lint",
    "@faker-js/faker": "catalog:script",
    "@tsconfig/node-lts": "catalog:types",
    "@tsconfig/node-ts": "catalog:types",
    "@tsconfig/strictest": "catalog:types",
    "@types/better-sqlite3": "catalog:script",
    "@types/eslint-plugin-jsx-a11y": "catalog:types",
    "@types/react": "catalog:conflicts_@types/react_h19_2_0",
    "@types/react-dom": "catalog:conflicts_@types/react-dom_h19_2_0",
    "@typescript-eslint/eslint-plugin": "catalog:lint",
    "better-sqlite3": "catalog:script",
    "drizzle-kit": "catalog:script",
    "eslint": "catalog:lint",
    "eslint-plugin-astro": "catalog:lint",
    "eslint-plugin-format": "catalog:lint",
    "eslint-plugin-import-lite": "catalog:lint",
    "eslint-plugin-jsx-a11y": "catalog:lint",
    "eslint-plugin-react-hooks": "catalog:lint",
    "eslint-plugin-react-refresh": "catalog:lint",
    "prettier-plugin-astro": "catalog:format",
    "tsx": "catalog:script",
    "typescript": "catalog:types",
    "wrangler": "catalog:infra"
  }
}
