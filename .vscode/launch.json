{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch: Fade",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/apps/fade",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "dev"
      ],
      "console": "internalConsole",
      "serverReadyAction": {
        "action": "debugWithChrome",
        "pattern": "Local:.*(http://localhost:[0-9]+)",
        "uriFormat": "%s",
        "webRoot": "${workspaceFolder}/apps/fade/src"
      },
    },
